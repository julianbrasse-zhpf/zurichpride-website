---
import { getEmDashEntry } from "emdash";

const { slug } = Astro.params;

// Destructure the result to extract the actual entry and the cache instructions
const { entry: event, cacheHint } = await getEmDashEntry("events", slug);

if (!event) {
  return Astro.redirect("/404");
}

// Enable automatic cache invalidation for this route
Astro.cache.set(cacheHint);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{event.data.title} | Zurich Pride</title>
  </head>
  <body>
    <main>
      <article>
        <h1>{event.data.title}</h1>
        {/* Adjust these fields based on what you created in the CMS */}
        <p>Date: {event.data.date}</p>
      </article>
    </main>
  </body>
</html>
